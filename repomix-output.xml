        <span style={{ fontVariantNumeric: 'tabular-nums', fontSize: 'var(--text-xs)', color: r.commission_amount > 0 ? 'var(--color-primary)' : 'var(--text-muted)' }}>
          {r.commission_amount > 0 ? fmt(r.commission_amount) : '—'}
        </span>
      ),
    },
    {
      key: 'bonus',
