-- =========================================================================
-- 09c_auth_guard.sql
-- التحقق من هوية المستخدم في جميع دوال RPC لضمان عدم تمرير p_user_id مزيف
-- =========================================================================
-- Generated: 2026-03-25T20:16:31.203Z
