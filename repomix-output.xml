  RAISE NOTICE '[16-v3] ✅ Bug-2: الإلغاء يعكس أرقام رأسية الفاتورة لـ DR:2100 و CR:1510';
  RAISE NOTICE '[16-v3] ✅ Bug-3: المرتجعات تحترم purchases.tax_enabled';
  RAISE NOTICE '[16-v3] ✅ Bug-4: subtotal خام + discount_amount صريح';
  RAISE NOTICE '[16-v3] ✅ Bug-5: CR:1300 = WAC الفعلي | فرق WAC → ±5300';
  RAISE NOTICE '[16-v3] ✅ Hotfix: vendor_payment/vendor_refund في add_vault_transaction';
