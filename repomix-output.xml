  sort_order  INTEGER DEFAULT 0,                         -- ترتيب المستويات (الأدنى أولاً)
  is_active   BOOLEAN DEFAULT true,
  created_at  TIMESTAMPTZ DEFAULT now(),
  UNIQUE(type, role_id)                                  -- F2: منع تكرار الدور في نفس النوع
);

