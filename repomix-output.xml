-- ════════════════════════════════════════════════════════════

CREATE TABLE IF NOT EXISTS hr_leave_requests (
  id                  UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  employee_id         UUID NOT NULL REFERENCES hr_employees(id),
  leave_type_id       UUID NOT NULL REFERENCES hr_leave_types(id),
