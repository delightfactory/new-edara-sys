  input: Partial<Pick<CustodyAccountInput, 'max_balance' | 'is_active'>>
) {
  const { data, error } = await supabase
    .from('custody_accounts')
    .update(input)
    .eq('id', id)
    .select()
    .single()
  if (error) throw error
  return data as CustodyAccount
}

