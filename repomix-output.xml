    .select()
    .single()
  if (error) throw error
  return data as ExpenseCategory
}

/**
 * تعديل تصنيف مصروف
 */
export async function updateExpenseCategory(id: string, input: {
  name?: string
  parent_id?: string | null
  is_active?: boolean
}) {
  const { data, error } = await supabase
    .from('expense_categories')
    .update(input)
    .eq('id', id)
    .select()
    .single()
  if (error) throw error
  return data as ExpenseCategory
