  id              UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  delegator_id    UUID NOT NULL REFERENCES hr_employees(id),  -- من يفوّض (المدير الغائب)
  delegate_id     UUID NOT NULL REFERENCES hr_employees(id),  -- من يتلقى التفويض
