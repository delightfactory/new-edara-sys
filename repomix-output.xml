      { key: 'hr.weekly_off_day',     label: 'يوم العطلة الأسبوعية',       type: 'select',  desc: 'الافتراضي للشركة',
        options: [
          { value: 'friday',   label: 'الجمعة' },
          { value: 'saturday', label: 'السبت' },
          { value: 'sunday',   label: 'الأحد' },
