CREATE POLICY "sri_read" ON sales_return_items FOR SELECT USING (
  EXISTS (SELECT 1 FROM sales_returns sr WHERE sr.id = return_id
    AND (sr.created_by = auth.uid() OR check_permission(auth.uid(), 'sales.returns.read')))
);

