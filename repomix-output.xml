  vaultId: string,
  amount: number,
  type: 'settlement' | 'return' = 'settlement',
) {
  const userId = (await supabase.auth.getUser()).data.user?.id
  const { error } = await supabase.rpc('settle_custody_to_vault', {
    p_custody_id: custodyId,
    p_vault_id: vaultId,
    p_amount: amount,
    p_type: type,
    p_user_id: userId,
  })
  if (error) throw error
}
