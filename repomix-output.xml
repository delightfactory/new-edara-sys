// ============================================================
// Expenses — المصروفات
// ============================================================

/**
 * جلب المصروفات مع التصفية والترقيم
 */
export async function getExpenses(params?: {
  status?: string
  categoryId?: string
  branchId?: string
  dateFrom?: string
  dateTo?: string
  page?: number
  pageSize?: number
}) {
  const page = params?.page || 1
